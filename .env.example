# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — get from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for Mini App metadata)
NEXT_PUBLIC_APP_URL=https://launch-forge-ten.vercel.app

# OnchainKit / CDP (required for in-app wallet funding)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your-onchainkit-public-api-key
NEXT_PUBLIC_CDP_PROJECT_ID=your-cdp-project-id

# Fishnet Auth secret for AI-agent authentication (generate a long random value)
FISHNET_AUTH_SECRET=replace-with-a-long-random-secret

# Token Factory (deployed on Base mainnet)
NEXT_PUBLIC_FACTORY_ADDRESS=0xYourFactoryAddressHere
